---
const { loveStory = [] } = Astro.props;
---
<div class="love-story">
  <h2>Kisah Cinta Kami</h2>
  <div class="timeline">
    {loveStory.map((item) => (
      <div class="timeline-item">
        <div class="year">{item.year}</div>
        <div class="content">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>
<style>
  .love-story {
    text-align: center;
    margin-top: 2rem;
    padding: 0 1rem;
    max-width: 100%;
  }
  
  h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #888;
    margin-bottom: 1.5rem;
  }
  
  .timeline {
    position: relative;
    padding-left: 1.5rem;
    max-width: 500px;
    margin: 0 auto;
    text-align: left;
  }
  
  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #c9a87c, rgba(201, 168, 124, 0.2));
  }
  
  .timeline-item {
    position: relative;
    padding-bottom: 1.5rem;
    transition: transform 0.2s ease;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }
  
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -1.5rem;
    top: 0.2rem;
    width: 10px;
    height: 10px;
    background: #c9a87c;
    border-radius: 50%;
    transition: transform 0.2s ease;
  }

  .timeline-item:active {
    transform: translateX(5px);
  }

  .timeline-item:active::before {
    transform: scale(1.3);
  }
  
  .year {
    font-size: 0.7rem;
    color: #c9a87c;
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 0.25rem;
  }
  
  .content h3 {
    margin: 0 0 0.25rem;
    color: #2c2c2c;
    font-size: 1rem;
    font-weight: 500;
  }
  
  .content p {
    margin: 0;
    color: #666;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .timeline {
      padding-left: 1.25rem;
    }

    .timeline::before {
      left: 0;
    }

    .timeline-item::before {
      left: -1.25rem;
    }

    .content h3 {
      font-size: 0.95rem;
    }

    .content p {
      font-size: 0.8rem;
    }
  }
</style>
