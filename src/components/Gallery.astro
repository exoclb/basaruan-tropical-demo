---
const { images = [] } = Astro.props;
---
<div class="gallery">
  <h2>Galeri</h2>
  <div class="grid">
    {images.map((img, index) => (
      <div class="image-wrapper reveal">
        <div class="overlay">
          <span class="icon">♡</span>
        </div>
        <img src={img} alt={`Photo ${index + 1}`} loading="lazy" />
      </div>
    ))}
  </div>
</div>
<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal');
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

  document.querySelectorAll('.image-wrapper').forEach(el => observer.observe(el));
</script>
<style>
  .gallery {
    text-align: center;
    margin-top: 2rem;
    padding: 0 0.5rem;
  }
  
  h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #888;
    margin-bottom: 1rem;
  }
  
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .grid > *:nth-child(3n+1) {
    grid-column: span 2;
  }
  
  .image-wrapper {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 8px;
    opacity: 0;
    transform: scale(0.9);
    transition: all 0.5s ease;
  }

  .grid > *:nth-child(3n+1) .image-wrapper {
    aspect-ratio: 2/1;
  }

  .image-wrapper.reveal {
    opacity: 1;
    transform: scale(1);
  }
  
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(201, 168, 124, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .overlay:active {
    opacity: 1;
  }

  .icon {
    font-size: 1.5rem;
    color: white;
  }
  
  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  .image-wrapper:active img {
    transform: scale(1.05);
  }

  @media (min-width: 600px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .grid > *:nth-child(3n+1) {
      grid-column: span 1;
    }

    .image-wrapper {
      aspect-ratio: 1;
    }

    .grid > *:nth-child(3n+1) .image-wrapper {
      aspect-ratio: 1;
    }

    .overlay {
      opacity: 0;
    }

    .image-wrapper:hover .overlay {
      opacity: 1;
    }

    .image-wrapper:hover img {
      transform: scale(1.05);
    }
  }

  @media (max-width: 400px) {
    .grid {
      gap: 0.4rem;
    }
  }
</style>
