---
import data from '../data/wedding.json';
const date = new Date(data.date);
const formattedDate = date.toLocaleDateString('id-ID', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---
<div class="hero">
  <p class="label">The Wedding of</p>
  <h1>{data.groom} <span class="ampersand">&</span> {data.bride}</h1>
  <p class="date">{formattedDate}</p>
  <p class="venue">{data.venue}</p>
</div>
<style>
  .hero {
    text-align: center;
    padding: 1.5rem 1rem 2rem;
    animation: fadeIn 0.8s ease;
  }
  
  .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #999;
    margin-bottom: 0.5rem;
    font-family: 'Lato', sans-serif;
  }
  
  h1 {
    font-size: clamp(2rem, 10vw, 3.5rem);
    margin: 0;
    color: #2c2c2c;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    line-height: 1.1;
  }
  
  .ampersand {
    color: #c9a87c;
    font-style: italic;
  }
  
  .date {
    font-size: 0.95rem;
    color: #666;
    margin-top: 1rem;
    letter-spacing: 0.5px;
    line-height: 1.4;
  }
  
  .venue {
    font-size: 0.85rem;
    color: #999;
    margin-top: 0.25rem;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 1rem 0.5rem 1.5rem;
    }

    .label {
      font-size: 0.65rem;
      letter-spacing: 2px;
    }

    .date {
      font-size: 0.85rem;
    }
  }
</style>
