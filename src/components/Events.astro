---
const { events = [] } = Astro.props;
---
<div class="events">
  <h2>Jadwal Acara</h2>
  <div class="event-list">
    {events.map((event) => (
      <div class="event-card">
        <h3>{event.name}</h3>
        <p class="time">{event.time}</p>
        <p class="location">{event.location}</p>
        {event.mapsUrl && (
          <a href={event.mapsUrl} target="_blank" rel="noopener noreferrer" class="maps-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            Lihat Maps
          </a>
        )}
      </div>
    ))}
  </div>
</div>
<style>
  .events {
    text-align: center;
    margin-top: 2rem;
    padding: 0 0.5rem;
  }
  
  h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #888;
    margin-bottom: 1rem;
  }
  
  .event-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 400px;
    margin: 0 auto;
  }
  
  .event-card {
    background: white;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: all 0.3s ease;
  }

  .event-card:active {
    transform: scale(0.98);
  }
  
  .event-card h3 {
    margin: 0 0 0.5rem;
    color: #2c2c2c;
    font-size: 1.1rem;
  }
  
  .event-card .time {
    color: #c9a87c;
    font-weight: 600;
    margin: 0;
    font-size: 0.95rem;
  }
  
  .event-card .location {
    color: #777;
    font-size: 0.85rem;
    margin: 0.5rem 0;
  }

  .maps-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: #c9a87c;
    color: white;
    text-decoration: none;
    font-size: 0.8rem;
    border-radius: 20px;
    transition: background 0.2s ease;
    width: 100%;
    max-width: 160px;
    box-sizing: border-box;
  }

  .maps-btn:active {
    background: #b8956a;
  }

  .maps-btn svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .event-card {
      padding: 1rem 1rem;
    }

    .event-card h3 {
      font-size: 1rem;
    }

    .maps-btn {
      max-width: 100%;
    }
  }
</style>
